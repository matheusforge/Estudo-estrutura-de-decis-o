algoritmo "Verificador_Dividendos"

var
   dy: real

inicio

   escreva("Digite o Dividend Yield (DY): ")
   leia(dy)

   se (dy > 6) entao
      escreva("Estrategia de Renda Passiva OK")
   senao
      se (dy >= 4) e (dy <= 6) entao
         escreva("Atencao: Rendimento Medio")
      senao
         escreva("Rendimento Baixo")
      fimse
   fimse

fimalgoritmo